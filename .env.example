# MedCare Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# Backend API Configuration
# Base URL without /api suffix (axios uses baseURL pattern)
VITE_API_BASE_URL=http://localhost:8080

# OAuth Configuration (for social login redirect+code flow)
# These are used for redirect URIs, not for client SDK initialization
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
VITE_FACEBOOK_REDIRECT_URI=http://localhost:5173/auth/facebook/callback

# Development flags
VITE_ENABLE_MOCK_API=false
VITE_ENABLE_MOCK_AUTH=false